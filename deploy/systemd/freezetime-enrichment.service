[Unit]
Description=FREEZETIME enrichment-worker (bölge/heatmap zenginleştirme)
After=network-online.target docker.service
Wants=network-online.target

[Service]
WorkingDirectory=/opt/freezetime/services/enrichment
EnvironmentFile=/opt/freezetime/infra/.env
Environment=PATH=/root/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/root/.local/bin/uv run --no-editable --quiet enrichment-worker
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
