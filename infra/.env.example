# Kopyala: cp .env.example .env  (gerçek değerleri .env'e yaz — .env git'e girmez)

# PostgreSQL
POSTGRES_USER=cs2
POSTGRES_PASSWORD=cs2dev
POSTGRES_DB=cs2
POSTGRES_URL=postgres://cs2:cs2dev@localhost:5432/cs2

# ClickHouse
CLICKHOUSE_USER=cs2
CLICKHOUSE_PASSWORD=cs2dev
CLICKHOUSE_DB=cs2
CLICKHOUSE_URL=http://localhost:8123

# MinIO / S3
MINIO_ROOT_USER=cs2minio
MINIO_ROOT_PASSWORD=cs2miniodev
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=demos
S3_REGION=us-east-1

# NATS
NATS_URL=nats://localhost:4222

# FACEIT entegrasyonu (opsiyonel)
# Data API anahtarı: https://developers.faceit.com → App → API key (anında)
FACEIT_API_KEY=
# Downloads API: https://fce.gg/downloads-api-application (onay ~30 gün).
# Onaylı anahtar farklıysa buraya; boşsa FACEIT_API_KEY kullanılır.
FACEIT_DOWNLOADS_KEY=

# Admin uçları (backfill/reprocess/coverage): boş = açık (yerel geliştirme).
# Üretimde MUTLAKA doldurun; arayüz ?admin=TOKEN ile bir kez tanıtılır.
ADMIN_TOKEN=

# 1 = işlenen backfill arşivini done/ yerine SİL (disk baskısı)
BACKFILL_DELETE_DONE=1

# Ham demo + tick saklama süresi (ay); meta/istatistik süresiz. 0=kapalı.
RETENTION_MONTHS=12
